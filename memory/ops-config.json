{
  "version": 2,
  "memorySearch": {
    "maxResults": 4,
    "maxSnippetChars": 300,
    "preferRecentDays": 3,
    "tierOrder": [
      "hot",
      "warm",
      "cold"
    ],
    "priorityFiles": [
      "MEMORY.md",
      "memory/open-loops.md",
      "memory/YYYY-MM-DD.md"
    ],
    "notes": "Keep recall high-signal and low-token; only expand scope when confidence is low."
  },
  "memoryFlush": {
    "enabled": true,
    "trigger": {
      "eventsSinceLastFlush": 6,
      "orMinutesSinceLastFlush": 120
    },
    "targetFilePattern": "memory/YYYY-MM-DD.md",
    "maxBulletsPerFlush": 4,
    "maxBulletChars": 150,
    "dedupeWindowDays": 2,
    "writeStyle": "concise-durable",
    "requireActionableOrDurable": true
  },
  "compaction": {
    "enabled": true,
    "scheduleHint": "heartbeat",
    "dailyCapLines": 70,
    "weeklySummaryFile": "memory/weekly-summary.md",
    "rollover": {
      "hotToWarmDays": 3,
      "warmToColdDays": 14
    },
    "archiveBeforeRewrite": true,
    "archivePath": "memory/archive/"
  }
}
